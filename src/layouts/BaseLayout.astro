---
const {
  title = 'SapkotaLab',
  description = "SapkotaLab at St. Jude Children's Research Hospital.",
  active = 'home',
} = Astro.props

const navItems = [
  { href: '/research/', label: 'Research', key: 'research' },
  { href: '/members/', label: 'Members', key: 'members' },
  { href: '/publications/', label: 'Publications', key: 'publications' },
  { href: '/news/', label: 'News', key: 'news' },
  { href: '/join-us/', label: 'Join Us', key: 'join-us' },
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --bg: #ffffff;
        --surface: #f8fafc;
        --border: #e2e8f0;
        --muted: #64748b;
        --text: #0f172a;
        --accent: #c8102e;
        --radius: 5px;
      }

      *, *::before, *::after { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        min-height: 100%;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        font-size: 1rem;
        line-height: 1.6;
        overflow-x: hidden;
      }

      img, svg, video { display: block; max-width: 100%; }

      a {
        color: inherit;
        text-decoration: none;
      }

      h1, h2, h3, h4 {
        margin: 0;
        line-height: 1.2;
        font-weight: 700;
      }

      p { margin: 0; }

      ul, ol { margin: 0; padding: 0; list-style: none; }

      ::selection { background: rgba(200, 16, 46, 0.12); }

      /* ---- LAYOUT ---- */
      .shell {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 clamp(1rem, 3vw, 2rem);
      }

      /* ---- HEADER ---- */
      header {
        border-bottom: 1px solid var(--border);
        background: #fff;
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 60px;
        gap: 1.5rem;
      }

      .brand {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text);
        text-decoration: none;
        white-space: nowrap;
        letter-spacing: -0.01em;
        flex-shrink: 0;
      }

      nav {
        display: flex;
        align-items: stretch;
      }

      nav a {
        display: flex;
        align-items: center;
        padding: 0 0.9rem;
        height: 60px;
        font-size: 0.9rem;
        color: var(--muted);
        text-decoration: none;
        border-bottom: 2px solid transparent;
        transition: color 150ms, border-color 150ms;
        white-space: nowrap;
      }

      nav a:hover {
        color: var(--text);
      }

      nav a[aria-current='page'] {
        color: var(--accent);
        border-bottom-color: var(--accent);
        font-weight: 600;
      }

      /* ---- MAIN ---- */
      main {
        padding: clamp(2rem, 5vw, 3.5rem) 0 clamp(3rem, 6vw, 5rem);
        display: grid;
        gap: clamp(2.5rem, 5vw, 3.5rem);
      }

      /* ---- HERO (homepage) ---- */
      .hero {
        padding-bottom: clamp(1.5rem, 3vw, 2.5rem);
        border-bottom: 1px solid var(--border);
      }

      .hero-lab {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.07em;
        margin-bottom: 0.75rem;
      }

      .hero h1 {
        font-size: clamp(1.75rem, 4.5vw, 3rem);
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -0.025em;
        max-width: 22ch;
        margin-bottom: 1rem;
      }

      .hero > p {
        font-size: 1.0625rem;
        color: var(--muted);
        max-width: 60ch;
        line-height: 1.65;
        margin-bottom: 1.75rem;
      }

      /* ---- PAGE HEADING (inner pages) ---- */
      .page-heading {
        padding-bottom: 1.75rem;
        border-bottom: 1px solid var(--border);
      }

      .page-label {
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.5rem;
      }

      .page-heading h1 {
        font-size: clamp(1.5rem, 4vw, 2.5rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 0.5rem;
      }

      .page-subtitle {
        font-size: 1rem;
        color: var(--muted);
        max-width: 60ch;
        line-height: 1.6;
      }

      /* ---- SECTION LABELS ---- */
      .section-label {
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.45rem;
      }

      .section-title {
        font-size: clamp(1.15rem, 2.5vw, 1.6rem);
        font-weight: 700;
        letter-spacing: -0.015em;
        margin-bottom: 1.5rem;
      }

      /* ---- BUTTONS ---- */
      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        padding: 0.6rem 1.2rem;
        border-radius: var(--radius);
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        transition: opacity 150ms, box-shadow 150ms;
        white-space: nowrap;
      }

      .btn:hover { opacity: 0.82; }

      .btn-primary {
        background: var(--accent);
        color: #fff;
      }

      .btn-secondary {
        background: transparent;
        color: var(--text);
        border: 1.5px solid var(--border);
      }

      /* ---- RESEARCH CARDS (homepage) ---- */
      .research-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 1.25rem;
      }

      .research-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-top: 3px solid var(--accent);
        border-radius: var(--radius);
        padding: 1.4rem 1.25rem;
      }

      .research-card h3 {
        font-size: 0.9375rem;
        font-weight: 700;
        margin-bottom: 0.6rem;
        line-height: 1.35;
      }

      .research-card p {
        font-size: 0.875rem;
        color: var(--muted);
        line-height: 1.55;
      }

      /* ---- TWO-COL (homepage bottom) ---- */
      .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2.5rem;
        align-items: start;
      }

      .col-block {
        border-top: 2px solid var(--accent);
        padding-top: 1.25rem;
      }

      /* ---- PUBLICATION / NEWS ROWS ---- */
      .pub-list {
        display: grid;
        gap: 0;
      }

      .pub-item {
        padding: 1rem 0;
        border-bottom: 1px solid var(--border);
      }

      .pub-item:first-child { padding-top: 0; }

      .pub-year {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 0.35rem;
      }

      .pub-title {
        font-size: 0.9rem;
        font-weight: 600;
        line-height: 1.4;
        margin-bottom: 0.25rem;
      }

      .pub-citation {
        font-size: 0.85rem;
        color: var(--muted);
        line-height: 1.5;
      }

      /* ---- FULL LIST (inner pages) ---- */
      .full-list {
        display: grid;
        gap: 0;
      }

      .list-item {
        padding: 1.75rem 0;
        border-bottom: 1px solid var(--border);
      }

      .list-item:first-child { padding-top: 0; }

      .item-label {
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.07em;
        margin-bottom: 0.4rem;
      }

      .item-title {
        font-size: 1.1rem;
        font-weight: 700;
        line-height: 1.3;
        margin-bottom: 0.5rem;
        letter-spacing: -0.01em;
      }

      .item-summary {
        font-size: 0.9rem;
        color: var(--muted);
        line-height: 1.6;
        max-width: 80ch;
      }

      .sources-row {
        margin-top: 0.75rem;
        font-size: 0.8rem;
        color: var(--muted);
      }

      .sources-row a {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 2px;
        word-break: break-all;
      }

      /* ---- CARD ---- */
      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.25rem;
      }

      .card h2 {
        font-size: 0.9rem;
        font-weight: 700;
        padding-bottom: 0.6rem;
        margin-bottom: 0.75rem;
        border-bottom: 1px solid var(--border);
      }

      /* ---- PROSE ---- */
      .prose p + p { margin-top: 0.75rem; }
      .prose h2 { font-size: 1rem; font-weight: 700; margin-top: 1.25rem; margin-bottom: 0.4rem; }
      .prose ul, .prose ol { padding-left: 1.25rem; list-style: disc; margin: 0.5rem 0; }
      .prose li { margin-bottom: 0.3rem; font-size: 0.9375rem; }

      /* ---- PROFILE LAYOUT ---- */
      .profile-layout {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2rem;
        align-items: start;
      }

      .profile-main p {
        font-size: 0.9375rem;
        line-height: 1.7;
      }

      .profile-main p + p { margin-top: 0.75rem; }

      .profile-meta {
        font-size: 0.85rem;
        color: var(--muted);
        margin-top: 0.75rem;
      }

      .profile-side {
        display: grid;
        gap: 1rem;
      }

      /* ---- JOIN LAYOUT ---- */
      .join-layout {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 2.5rem;
        align-items: start;
      }

      .arrow-list {
        display: grid;
        gap: 0.6rem;
      }

      .arrow-list li {
        display: flex;
        gap: 0.65rem;
        align-items: flex-start;
        font-size: 0.9375rem;
      }

      .arrow-list li::before {
        content: '→';
        color: var(--accent);
        font-weight: 700;
        flex-shrink: 0;
        margin-top: 0.05em;
      }

      /* ---- TEXT UTILS ---- */
      .text-muted { color: var(--muted); }
      .text-small { font-size: 0.875rem; }
      .text-accent { color: var(--accent); }

      /* ---- FOOTER ---- */
      footer {
        border-top: 1px solid var(--border);
        padding: 1.5rem 0;
        font-size: 0.875rem;
        color: var(--muted);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }

      footer a {
        color: var(--muted);
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition: color 150ms;
      }

      footer a:hover { color: var(--text); }

      .nav-github {
        display: flex;
        align-items: center;
        padding: 0 0.75rem;
        height: 60px;
        color: var(--muted);
        transition: color 150ms;
      }

      .nav-github:hover { color: var(--text); }

      /* ---- RESPONSIVE ---- */
      @media (max-width: 820px) {
        .two-col,
        .profile-layout,
        .join-layout {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 700px) {
        .header-inner {
          height: auto;
          flex-direction: column;
          align-items: flex-start;
          padding: 0.75rem 0;
          gap: 0;
        }

        nav {
          flex-wrap: wrap;
          margin-top: 0.25rem;
        }

        nav a {
          height: auto;
          padding: 0.4rem 0.6rem;
          border-bottom: none;
          font-size: 0.875rem;
        }

        nav a[aria-current='page'] {
          border-bottom: none;
          color: var(--accent);
          font-weight: 600;
        }

        header { position: relative; }
      }

      @media (max-width: 540px) {
        .research-grid {
          grid-template-columns: 1fr;
        }

        .actions {
          flex-direction: column;
        }

        .btn { width: 100%; justify-content: center; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="shell">
        <div class="header-inner">
          <a class="brand" href="/">SapkotaLab</a>
          <nav aria-label="Primary">
            {navItems.map((item) => (
              <a href={item.href} aria-current={active === item.key ? 'page' : undefined}>
                {item.label}
              </a>
            ))}
            <a href="https://github.com/SapkotaLab" target="_blank" rel="noreferrer" class="nav-github" aria-label="GitHub">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.014-1.703-2.782.604-3.369-1.341-3.369-1.341-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
              </svg>
            </a>
          </nav>
        </div>
      </div>
    </header>
    <div class="shell">
      <main>
        <slot />
      </main>
      <footer>
        <span>&copy; {new Date().getFullYear()} SapkotaLab &mdash; St. Jude Children&rsquo;s Research Hospital</span>
        <a href="https://github.com/SapkotaLab" target="_blank" rel="noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.014-1.703-2.782.604-3.369-1.341-3.369-1.341-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
          GitHub
        </a>
      </footer>
    </div>
  </body>
</html>
