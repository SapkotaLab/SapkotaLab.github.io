---
const {
  title = 'SapkotaLab',
  description = "SapkotaLab at St. Jude Children's Research Hospital.",
  active = 'home',
} = Astro.props

const navItems = [
  { href: '/research/', label: 'Research', key: 'research' },
  { href: '/members/', label: 'Members', key: 'members' },
  { href: '/publications/', label: 'Publications', key: 'publications' },
  { href: '/news/', label: 'News', key: 'news' },
  { href: '/join-us/', label: 'Join Us', key: 'join-us' },
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: light;
        font-family: 'Avenir Next', Avenir, 'Segoe UI', Helvetica, Arial, sans-serif;
        line-height: 1.5;
        font-weight: 400;
        background: #f4f7f5;
        color: #10212a;
        --bg: #f4f7f5;
        --surface: rgba(255, 255, 255, 0.88);
        --surface-strong: #ffffff;
        --surface-soft: #edf3f0;
        --border: #d4ddd8;
        --muted: #59656b;
        --text: #10212a;
        --accent: #0f766e;
        --accent-2: #1d4ed8;
        --accent-3: #d97706;
        --shadow: 0 14px 30px rgba(16, 33, 42, 0.08);
        --radius: 8px;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
        background: var(--bg);
        overflow-x: hidden;
      }

      body {
        color: var(--text);
        background:
          linear-gradient(135deg, rgba(15, 118, 110, 0.08), transparent 34%),
          linear-gradient(225deg, rgba(29, 78, 216, 0.06), transparent 36%),
          linear-gradient(180deg, #fbfcfb 0%, #f4f7f5 38%, #eef3f1 100%);
        overflow-x: hidden;
      }

      img,
      svg,
      video,
      canvas {
        display: block;
        max-width: 100%;
      }

      ::selection {
        background: rgba(15, 118, 110, 0.18);
      }

      a {
        color: inherit;
        text-decoration-thickness: 0.08em;
        text-underline-offset: 0.18em;
        overflow-wrap: anywhere;
      }

      a:hover {
        text-decoration-color: currentColor;
      }

      .shell {
        width: 100%;
        max-width: 1180px;
        margin: 0 auto;
        padding: clamp(1rem, 2vw, 1.5rem);
      }

      header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1.5rem;
        padding: 0.25rem 0 1rem;
        border-bottom: 1px solid var(--border);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, serif;
        font-size: 1.08rem;
        font-weight: 700;
        text-decoration: none;
        letter-spacing: 0;
      }

      .brand::before {
        content: '';
        width: 0.85rem;
        height: 0.85rem;
        flex: none;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        box-shadow: 0 0 0 5px rgba(15, 118, 110, 0.08);
      }

      nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 0.45rem;
      }

      nav a {
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        text-decoration: none;
        color: var(--muted);
        border: 1px solid transparent;
        transition:
          border-color 180ms ease,
          background-color 180ms ease,
          color 180ms ease,
          transform 180ms ease;
      }

      nav a:hover {
        background: rgba(255, 255, 255, 0.64);
        border-color: var(--border);
        transform: translateY(-1px);
      }

      nav a[aria-current='page'] {
        background: rgba(16, 33, 42, 0.94);
        color: #fff;
      }

      main {
        padding: clamp(1.5rem, 4vw, 3.25rem) 0 clamp(2.5rem, 5vw, 4rem);
        display: grid;
        gap: clamp(1.25rem, 2.5vw, 2rem);
        min-width: 0;
      }

      main > * {
        min-width: 0;
      }

      .stack {
        display: grid;
        gap: 1rem;
      }

      main > section + section {
        margin-top: clamp(0.5rem, 1vw, 1rem);
      }

      .eyebrow {
        margin: 0;
        display: inline-flex;
        width: fit-content;
        align-items: center;
        gap: 0.45rem;
        text-transform: uppercase;
        letter-spacing: 0;
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--accent);
      }

      h1,
      h2,
      h3 {
        margin: 0;
        font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, serif;
        line-height: 1.12;
        letter-spacing: 0;
        overflow-wrap: anywhere;
      }

      p {
        margin: 0;
        overflow-wrap: anywhere;
        max-width: 100%;
      }

      .hero {
        display: grid;
        gap: 1rem;
        max-width: 76ch;
        min-width: 0;
      }

      .hero-copy {
        display: grid;
        gap: 1rem;
        align-content: start;
      }

      .home-hero {
        position: relative;
        min-height: 26rem;
        overflow: hidden;
        max-width: none;
        padding: clamp(1.25rem, 4vw, 2.6rem);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background:
          linear-gradient(90deg, rgba(251, 252, 251, 0.96) 0%, rgba(251, 252, 251, 0.9) 48%, rgba(251, 252, 251, 0.62) 100%),
          linear-gradient(135deg, rgba(15, 118, 110, 0.14), rgba(29, 78, 216, 0.1) 48%, rgba(217, 119, 6, 0.12));
        box-shadow: var(--shadow);
        align-content: center;
      }

      .home-hero .hero-copy {
        position: relative;
        z-index: 2;
        max-width: 34rem;
      }

      .hero-art {
        position: absolute;
        z-index: 1;
        inset: 50% 1.1rem auto auto;
        width: min(44%, 34rem);
        transform: translateY(-50%);
        opacity: 0.38;
        pointer-events: none;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 0;
        max-width: 100%;
        padding: 0.78rem 1rem;
        border-radius: var(--radius);
        border: 1px solid var(--text);
        text-decoration: none;
        font-weight: 600;
        text-align: center;
        white-space: normal;
        overflow-wrap: anywhere;
        transition:
          transform 180ms ease,
          box-shadow 180ms ease,
          background-color 180ms ease,
          color 180ms ease,
          border-color 180ms ease;
      }

      .button:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow);
      }

      .button.secondary {
        border-color: var(--border);
        background: rgba(255, 255, 255, 0.54);
      }

      .grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        min-width: 0;
      }

      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1rem;
        box-shadow: var(--shadow);
        min-width: 0;
      }

      .card h2,
      .card h3 {
        font-size: 1.05rem;
        margin-bottom: 0.5rem;
      }

      .meta {
        color: var(--muted);
        font-size: 0.95rem;
      }

      .prose {
        max-width: 70ch;
      }

      .prose > * + * {
        margin-top: 0.8rem;
      }

      .prose ul {
        padding-left: 1.15rem;
        margin: 0;
      }

      .prose li + li {
        margin-top: 0.3rem;
      }

      .list {
        display: grid;
        gap: 1rem;
        min-width: 0;
      }

      .list-item {
        position: relative;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1rem 1rem 1rem 1.05rem;
        box-shadow: var(--shadow);
        min-width: 0;
      }

      .sources {
        font-size: 0.9rem;
        color: var(--muted);
        word-break: break-word;
        overflow-wrap: anywhere;
        line-height: 1.45;
      }

      .sources a {
        color: var(--accent-2);
        word-break: break-all;
        overflow-wrap: anywhere;
      }

      footer {
        padding: 1rem 0 0.5rem;
        color: var(--muted);
        font-size: 0.92rem;
      }

      .page-heading {
        display: grid;
        gap: 0.65rem;
        max-width: min(72ch, 100%);
        min-width: 0;
      }

      .section-heading {
        display: grid;
        gap: 0.5rem;
        margin-bottom: 0.9rem;
        min-width: 0;
      }

      .section-heading h2 {
        font-size: 1.55rem;
      }

      .chip-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .chip {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.42rem 0.7rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.8);
        border: 1px solid var(--border);
        color: var(--muted);
        font-size: 0.88rem;
      }

      .data-graphic {
        overflow: hidden;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(246, 250, 248, 0.92), rgba(232, 240, 238, 0.96));
      }

      .data-graphic figcaption {
        padding: 0.8rem 0.95rem 0.95rem;
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.45;
      }

      .member-grid {
        grid-template-columns: repeat(12, minmax(0, 1fr));
      }

      .member-main {
        grid-column: 1 / -1;
      }

      .member-side {
        grid-column: span 6;
      }

      .join-grid {
        grid-template-columns: minmax(0, 1fr) minmax(280px, 0.82fr);
        align-items: start;
      }

      .join-panel {
        align-self: start;
      }

      .publication-row {
        display: grid;
        gap: 0.45rem;
      }

      .publication-year {
        display: inline-flex;
        width: fit-content;
        align-items: center;
        padding: 0.28rem 0.55rem;
        border-radius: 999px;
        background: rgba(15, 118, 110, 0.1);
        color: var(--accent);
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0;
        text-transform: uppercase;
      }

      @media (max-width: 840px) {
        header {
          flex-direction: column;
        }

        nav {
          justify-content: flex-start;
        }

        .join-grid {
          grid-template-columns: 1fr;
        }

        .home-hero {
          min-height: 0;
          padding-bottom: 1.25rem;
        }

        .hero-art {
          position: relative;
          inset: auto;
          width: 100%;
          transform: none;
          opacity: 0.9;
          margin-top: 1rem;
        }

        .member-side {
          grid-column: 1 / -1;
        }
      }

      @media (max-width: 640px) {
        .shell {
          padding-inline: 0.9rem;
        }

        .actions {
          display: grid;
        }

        .button {
          width: 100%;
        }

        .grid {
          grid-template-columns: 1fr;
        }

        .member-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header>
        <a class="brand" href="/">SapkotaLab</a>
        <nav aria-label="Primary">
          {navItems.map((item) => (
            <a href={item.href} aria-current={active === item.key ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer>St. Jude Children's Research Hospital</footer>
    </div>
  </body>
</html>
