---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

const news = (await getCollection('news')).slice().sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
---

<BaseLayout title="News | SapkotaLab" description="Recent news related to the SapkotaLab." active="news">

  <section class="page-heading">
    <div class="page-label">News</div>
    <h1>Recent Updates</h1>
    <p class="page-subtitle">St. Jude stories and releases that track the lab's research progress.</p>
  </section>

  <section class="full-list">
    {news.map((item) => (
      <article class="list-item">
        <div class="item-label">{item.data.date.toISOString().slice(0, 10)}</div>
        <h2 class="item-title">{item.data.title}</h2>
        <p class="item-summary">{item.data.summary}</p>
        <div class="sources-row">
          {item.data.sourceUrls.map((url, index) => (
            <>
              {index > 0 ? ' · ' : null}
              <a href={url} target="_blank" rel="noreferrer">Source {index + 1}</a>
            </>
          ))}
        </div>
      </article>
    ))}
  </section>

</BaseLayout>
