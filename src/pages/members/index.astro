---
import { getEntry, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

const person = await getEntry('people', 'yadav-sapkota')
const { Content } = await render(person)
---

<BaseLayout title="Members | SapkotaLab" description="Lab member and PI information." active="members">

  <section class="page-heading">
    <div class="page-label">Members</div>
    <h1>{person.data.name}</h1>
    <p class="page-subtitle">{person.data.role} &mdash; {person.data.department}</p>
  </section>

  <section class="profile-layout">
    <article class="profile-main prose">
      <p>{person.data.summary}</p>
      <p class="profile-meta">
        {person.data.institution} &nbsp;|&nbsp; {person.data.location} &nbsp;|&nbsp;
        <a href={`mailto:${person.data.email}`} style="color: var(--accent);">{person.data.email}</a>
      </p>
      <Content />
      <p class="profile-meta">Phone: {person.data.phone} &nbsp;|&nbsp; Fax: {person.data.fax}</p>
      <div class="sources-row">
        Sources:{' '}
        {person.data.sourceUrls.map((url, index) => (
          <>
            {index > 0 ? ', ' : null}
            <a href={url} target="_blank" rel="noreferrer">{url}</a>
          </>
        ))}
      </div>
    </article>

    <aside class="profile-side">
      <div class="card">
        <h2>Education</h2>
        <ul style="display: grid; gap: 0.4rem;">
          {person.data.education.map((item) => (
            <li style="font-size: 0.875rem; color: var(--muted);">{item}</li>
          ))}
        </ul>
      </div>

      <div class="card">
        <h2>Affiliations</h2>
        <ul style="display: grid; gap: 0.4rem;">
          {person.data.affiliations.map((item) => (
            <li style="font-size: 0.875rem; color: var(--muted);">{item}</li>
          ))}
        </ul>
      </div>

      <div class="card">
        <h2>Research Interests</h2>
        <ul style="display: grid; gap: 0.4rem;">
          {person.data.researchInterests.map((item) => (
            <li style="font-size: 0.875rem; color: var(--muted);">{item}</li>
          ))}
        </ul>
      </div>

      <div class="card">
        <h2>Mailing Address</h2>
        <p style="font-size: 0.875rem; color: var(--muted); line-height: 1.7;">
          {person.data.mailingAddress.map((line, index) => (
            <>
              {index > 0 ? <br /> : null}
              {line}
            </>
          ))}
        </p>
      </div>
    </aside>
  </section>

</BaseLayout>
