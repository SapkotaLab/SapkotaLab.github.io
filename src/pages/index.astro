---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'

const people = await getCollection('people')
const person = people[0]
const research = (await getCollection('research')).sort((a, b) => a.data.order - b.data.order)
const publications = (await getCollection('publications'))
  .slice()
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3)
const news = (await getCollection('news'))
  .slice()
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)
---

<BaseLayout title="SapkotaLab" description="Clinical and genomic survivorship research at St. Jude." active="home">

  <section class="hero">
    <div class="hero-lab">St. Jude Children&rsquo;s Research Hospital</div>
    <h1>Research on long-term effects of childhood cancer treatment</h1>
    <p>{person.data.summary}</p>
    <div class="actions">
      <a class="btn btn-primary" href="/research/">Explore Research</a>
      <a class="btn btn-secondary" href="/members/">Meet the Lab</a>
    </div>
  </section>

  <section>
    <div class="section-label">Current Focus</div>
    <h2 class="section-title">Research Themes</h2>
    <div class="research-grid">
      {research.map((item) => (
        <article class="research-card">
          <h3>{item.data.title}</h3>
          <p>{item.data.summary}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="two-col">
    <div class="col-block">
      <div class="section-label">Selected Work</div>
      <h2 class="section-title" style="font-size: 1.2rem; margin-bottom: 1.25rem;">Publications</h2>
      <div class="pub-list">
        {publications.map((pub) => (
          <article class="pub-item">
            <span class="pub-year">{pub.data.year}</span>
            <p class="pub-title">{pub.data.title}</p>
            <p class="pub-citation">{pub.data.citation}</p>
          </article>
        ))}
      </div>
      <a href="/publications/" class="btn btn-secondary" style="margin-top: 1.25rem; font-size: 0.85rem;">
        All publications →
      </a>
    </div>

    <div class="col-block">
      <div class="section-label">Recent Updates</div>
      <h2 class="section-title" style="font-size: 1.2rem; margin-bottom: 1.25rem;">News</h2>
      <div class="pub-list">
        {news.map((item) => (
          <article class="pub-item">
            <span class="pub-year">{item.data.date.toISOString().slice(0, 10)}</span>
            <p class="pub-title">{item.data.title}</p>
            <p class="pub-citation">{item.data.summary}</p>
          </article>
        ))}
      </div>
      <a href="/news/" class="btn btn-secondary" style="margin-top: 1.25rem; font-size: 0.85rem;">
        All updates →
      </a>
    </div>
  </section>

</BaseLayout>
