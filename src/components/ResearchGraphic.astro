---
const { decorative = false, showCaption = true } = Astro.props
---

<figure class="data-graphic" aria-hidden={decorative ? 'true' : undefined}>
  <svg
    viewBox="0 0 640 420"
    role={decorative ? undefined : 'img'}
    aria-labelledby={decorative ? undefined : 'research-graphic-title research-graphic-desc'}
  >
    {!decorative && (
      <>
        <title id="research-graphic-title">Illustrative survivorship research graphic</title>
        <desc id="research-graphic-desc">
          An abstract scientific line chart with multiple trajectories, used as a non-photographic
          visual accent for the lab homepage.
        </desc>
      </>
    )}
    <defs>
      <linearGradient id="bg-gradient" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#f9fcfb" />
        <stop offset="55%" stop-color="#eef5f2" />
        <stop offset="100%" stop-color="#e5eff1" />
      </linearGradient>
      <linearGradient id="teal-line" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#0f766e" />
        <stop offset="100%" stop-color="#14b8a6" />
      </linearGradient>
      <linearGradient id="blue-line" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#1d4ed8" />
        <stop offset="100%" stop-color="#3b82f6" />
      </linearGradient>
      <linearGradient id="amber-line" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#c2410c" />
        <stop offset="100%" stop-color="#f59e0b" />
      </linearGradient>
      <filter id="soft-shadow" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="0" dy="12" stdDeviation="14" flood-color="#10212a" flood-opacity="0.12" />
      </filter>
    </defs>

    <rect x="18" y="18" width="604" height="384" rx="18" fill="url(#bg-gradient)" stroke="#d4ddd8" />

    <g opacity="0.75">
      <path d="M92 76V318" stroke="#cfd9d5" stroke-width="1" />
      <path d="M172 76V318" stroke="#cfd9d5" stroke-width="1" />
      <path d="M252 76V318" stroke="#cfd9d5" stroke-width="1" />
      <path d="M332 76V318" stroke="#cfd9d5" stroke-width="1" />
      <path d="M412 76V318" stroke="#cfd9d5" stroke-width="1" />
      <path d="M492 76V318" stroke="#cfd9d5" stroke-width="1" />
      <path d="M572 76V318" stroke="#cfd9d5" stroke-width="1" />
      <path d="M92 88H572" stroke="#cfd9d5" stroke-width="1" />
      <path d="M92 148H572" stroke="#cfd9d5" stroke-width="1" />
      <path d="M92 208H572" stroke="#cfd9d5" stroke-width="1" />
      <path d="M92 268H572" stroke="#cfd9d5" stroke-width="1" />
    </g>

    <path d="M92 318H572" stroke="#4b5d65" stroke-width="2" />
    <path d="M92 76V318" stroke="#4b5d65" stroke-width="2" />

    <g fill="#60737a" font-family="Avenir Next, Segoe UI, Helvetica, Arial, sans-serif" font-size="14">
      <text x="558" y="344" text-anchor="end">time</text>
      <text x="42" y="88" transform="rotate(-90 42 88)">signal</text>
    </g>

    <path
      d="M102 286 C150 266, 172 244, 204 228 S286 206, 320 182 S398 130, 448 122 S520 110, 564 92"
      fill="none"
      stroke="url(#teal-line)"
      stroke-width="5"
      stroke-linecap="round"
      stroke-linejoin="round"
      filter="url(#soft-shadow)"
    />
    <path
      d="M102 250 C140 238, 172 214, 216 220 S298 244, 338 224 S400 174, 448 166 S508 172, 564 150"
      fill="none"
      stroke="url(#blue-line)"
      stroke-width="5"
      stroke-linecap="round"
      stroke-linejoin="round"
      opacity="0.95"
    />
    <path
      d="M102 146 C136 150, 176 168, 216 188 S292 244, 336 246 S412 216, 452 192 S516 158, 564 132"
      fill="none"
      stroke="url(#amber-line)"
      stroke-width="5"
      stroke-linecap="round"
      stroke-linejoin="round"
      opacity="0.95"
    />

    <g>
      <circle cx="204" cy="228" r="6" fill="#0f766e" />
      <circle cx="320" cy="182" r="6" fill="#0f766e" />
      <circle cx="448" cy="122" r="6" fill="#0f766e" />

      <circle cx="216" cy="220" r="6" fill="#1d4ed8" />
      <circle cx="338" cy="224" r="6" fill="#1d4ed8" />
      <circle cx="448" cy="166" r="6" fill="#1d4ed8" />

      <circle cx="216" cy="188" r="6" fill="#d97706" />
      <circle cx="336" cy="246" r="6" fill="#d97706" />
      <circle cx="452" cy="192" r="6" fill="#d97706" />
    </g>

    <g transform="translate(388 54)">
      <rect x="0" y="0" width="176" height="90" rx="14" fill="#ffffff" stroke="#d4ddd8" />
      <circle cx="24" cy="24" r="5" fill="#0f766e" />
      <text x="38" y="29" fill="#31434a" font-family="Avenir Next, Segoe UI, Helvetica, Arial, sans-serif" font-size="14">
        clinical data
      </text>
      <circle cx="24" cy="49" r="5" fill="#1d4ed8" />
      <text x="38" y="54" fill="#31434a" font-family="Avenir Next, Segoe UI, Helvetica, Arial, sans-serif" font-size="14">
        molecular signals
      </text>
      <circle cx="24" cy="74" r="5" fill="#d97706" />
      <text x="38" y="79" fill="#31434a" font-family="Avenir Next, Segoe UI, Helvetica, Arial, sans-serif" font-size="14">
        functional models
      </text>
    </g>
  </svg>
  {showCaption && (
    <figcaption>Illustrative framework for clinical, molecular, and functional survivorship research.</figcaption>
  )}
</figure>
